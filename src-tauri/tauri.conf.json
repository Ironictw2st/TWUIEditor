{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TWUI Editor",
  "version": "0.0.3",
  "identifier": "com.twui.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TWUI Editor",
        "width": 1600,
        "height": 1000,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost twuiimg: http://twuiimg.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyMzRDMzkzMDRBMDdEMUQKUldRZGZhQUVrOE0wa2pBSWNlM3dpU1AvZFlGckJ3cTdHajlqUSt1N29BRklpMzlOOWlMMkVvLzEK",
      "endpoints": [
        "https://github.com/Ironictw2st/TWUIEditor/releases/latest/download/latest.json"
      ]
    }
  }
}
