# Copy this file to `.env` (same folder) and fill in the value, then rebuild.
# The build script (build.rs) reads .env and bakes the webhook into the binary.

# Discord webhook the in-app bug reporter posts to.
# Discord: Server Settings > Integrations > Webhooks > New Webhook > Copy Webhook URL.
TWUI_BUG_WEBHOOK=https://discord.com/api/webhooks/000000000000000000/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
